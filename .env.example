# Supabase (usado pelo frontend Next.js e backend Python)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend Python - Supabase (usar os mesmos valores acima)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# OpenAI (usado para chat do briefing)
OPENAI_API_KEY=your_openai_api_key

# Resend (Email - opcional)
RESEND_API_KEY=your_resend_api_key

# Google OAuth (Calendar - opcional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend Python - Database (opcional, se usar PostgreSQL local)
# POSTGRES_SERVER=127.0.0.1
# POSTGRES_USER=crm_user
# POSTGRES_PASSWORD=crm_password
# POSTGRES_DB=crm_db
# POSTGRES_PORT=5433

# SDR Agent (LangGraph) - para agente de vendas automatizado
GROQ_API_KEY=your_groq_api_key
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_TRACING=true
# GROQ_MODEL=openai/gpt-oss-20b
